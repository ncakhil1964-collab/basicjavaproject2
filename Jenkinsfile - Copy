pipeline {
    agent any

    tools {
        maven 'mymaven'   // must match Maven installation name in Jenkins
        jdk 'jdk21'       // or jdk17 depending on your project
    }

    stages {
        stage('Code Checkout') {
            steps {
                checkout changelog: false, poll: false, scm: scmGit(
                    branches: [[name: '*/master']],
                    extensions: [],
                    userRemoteConfigs: [[
                        credentialsId: 'GitHubCreds',
                        url: 'https://github.com/ncakhil1964-collab/basicjavaproject2'
                    ]]
                )
            }
        }

        stage('Build Automation') {
            steps {
                sh '''
                    ls -lart
                    mvn -version
                    mvn clean install
                    ls -lart target
                '''
            }
        }

        stage('Code Deployment') {
            steps {
                sh 'pkill -f "java -jar" || true'
                sh 'nohup java -jar target/*.jar > app.log 2>&1 &'
            }
        }
    }

    post {
        success {
            echo 'Pipeline finished successfully!'
        }
        failure {
            echo 'Pipeline failed!'
        }
    }
}
